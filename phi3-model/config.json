// ============================================================================
// FILE: marisselle-teacher/phi3-model/config.json
// MODEL CONFIGURATION FOR phi3-mini
// ============================================================================
{
  "model_type": "phi3",
  "vocab_size": 32064,
  "hidden_size": 3072,
  "intermediate_size": 8192,
  "num_hidden_layers": 32,
  "num_attention_heads": 32,
  "num_key_value_heads": 8,
  "hidden_act": "silu",
  "max_position_embeddings": 4096,
  "rms_norm_eps": 1e-5,
  "rope_theta": 10000.0,
  "sliding_window": 2048,
  "quantization": "q4_K_M",
  "quantization_config": {
    "quant_method": "gguf",
    "bits": 4,
    "group_size": 32,
    "symmetric": true
  },
  "tokenizer_config": {
    "tokenizer_class": "LlamaTokenizer",
    "chat_template": "{% for message in messages %}{{'<|' + message['role'] + '|>\n' + message['content'] + '<|end|>\n'}}{% endfor %}{% if add_generation_prompt %}{{'<|assistant|>\n'}}{% endif %}"
  }
}
